generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
  PENDING_VERIFICATION
  LOCKED
  DELETED
}

enum AuthProviderType {
  GOOGLE
  FACEBOOK
  APPLE
}

enum EntityType {
  ORDER
  PRODUCT
  USER
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
  SHIPPED
  DELIVERED
  REFUNDED
}

enum PaymentStatus {
  INITIATED
  SUCCESS
  FAILED
  REFUNDED
}

enum PaymentMethod {
  CARD
  UPI
  NETBANKING
  WALLET
}

enum RefundStatus {
  PENDING
  SUCCESS
  FAILED
}

model Account {
  id                 BigInt              @id @default(autoincrement())
  publicId           String              @unique @db.Char(36)
  email              String              @unique
  username           String              @unique
  status             AccountStatus       @default(PENDING_VERIFICATION)
  isEmailVerified    Boolean             @default(false)
  lastLoginAt        DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  deletedAt          DateTime?
  credential         Credential?
  sessions           Session[]
  providers          AuthProvider[]
  emailVerifications EmailVerification[]
  roles              AccountRole[]
  profile            CustomerProfile?
  addresses          Address[]
  stats              CustomerStats?
  auditLogs          AuditLog[]
  orders             Order[]

  @@index([email])
  @@index([username])
}

model Credential {
  id              BigInt @id @default(autoincrement())
  accountPublicId String @unique

  passwordHash      String
  passwordChangedAt DateTime?
  failedAttempts    Int       @default(0)
  lockedUntil       DateTime?

  account Account @relation(fields: [accountPublicId], references: [publicId], onDelete: Cascade)
}

model AuthProvider {
  id              BigInt @id @default(autoincrement())
  accountPublicId String

  provider       AuthProviderType
  providerUserId String
  accessToken    String?
  refreshToken   String?
  createdAt      DateTime         @default(now())

  account Account @relation(fields: [accountPublicId], references: [publicId], onDelete: Cascade)

  @@unique([provider, providerUserId])
}

model Session {
  id              BigInt @id @default(autoincrement())
  accountPublicId String

  refreshTokenHash String
  ipAddress        String?
  userAgent        String?
  deviceName       String?
  expiresAt        DateTime
  createdAt        DateTime  @default(now())
  revokedAt        DateTime?

  account Account @relation(fields: [accountPublicId], references: [publicId], onDelete: Cascade)

  @@index([accountPublicId, revokedAt])
}

model EmailVerification {
  id              BigInt @id @default(autoincrement())
  accountPublicId String

  email     String
  tokenHash String
  ipAddress String?
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  account Account @relation(fields: [accountPublicId], references: [publicId], onDelete: Cascade)
}

model Role {
  id          BigInt           @id @default(autoincrement())
  name        String           @unique
  description String?
  permissions RolePermission[]
  accounts    AccountRole[]
}

model Permission {
  id          BigInt           @id @default(autoincrement())
  code        String           @unique
  description String?
  roles       RolePermission[]
}

model RolePermission {
  roleId       BigInt
  permissionId BigInt

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model AccountRole {
  accountPublicId String
  roleId          BigInt
  assignedAt      DateTime @default(now())

  account Account @relation(fields: [accountPublicId], references: [publicId], onDelete: Cascade)
  role    Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([accountPublicId, roleId])
}

model CustomerProfile {
  id              BigInt @id @default(autoincrement())
  accountPublicId String @unique

  firstName    String
  lastName     String
  phone        String?
  profileImage String?
  dateOfBirth  DateTime?
  gender       String?

  account Account @relation(fields: [accountPublicId], references: [publicId], onDelete: Cascade)
}

model Address {
  id              BigInt @id @default(autoincrement())
  accountPublicId String

  label      String?
  fullName   String
  phone      String
  line1      String
  line2      String?
  city       String
  state      String
  country    String
  postalCode String
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())

  account Account @relation(fields: [accountPublicId], references: [publicId], onDelete: Cascade)

  @@index([accountPublicId, isDefault])
}

model CustomerStats {
  accountPublicId String @id

  totalOrders   Int       @default(0)
  totalSpent    Decimal   @default(0.00) @db.Decimal(12, 2)
  totalRefunds  Decimal   @default(0.00) @db.Decimal(12, 2)
  lifetimeValue Decimal   @default(0.00) @db.Decimal(12, 2)
  lastOrderAt   DateTime?

  account Account @relation(fields: [accountPublicId], references: [publicId], onDelete: Cascade)
}

model AuditLog {
  id              BigInt  @id @default(autoincrement())
  accountPublicId String?

  action     String
  entityType String
  entityId   String
  oldData    Json?
  newData    Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  account Account? @relation(fields: [accountPublicId], references: [publicId])
}

model GuestCheckout {
  id         BigInt   @id @default(autoincrement())
  fullName   String
  email      String
  phone      String
  line1      String
  line2      String?
  city       String
  state      String
  country    String
  postalCode String
  createdAt  DateTime @default(now())
}

model Order {
  id              BigInt      @id @default(autoincrement())
  orderNumber     String      @unique
  accountPublicId String
  status          OrderStatus @default(PENDING)

  subtotal    Decimal @db.Decimal(12, 2)
  tax         Decimal @db.Decimal(12, 2)
  shippingFee Decimal @db.Decimal(12, 2)
  totalAmount Decimal @db.Decimal(12, 2)

  currency String @default("INR")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account  Account     @relation(fields: [accountPublicId], references: [publicId])
  items    OrderItem[]
  payments Payment[]

  @@index([accountPublicId])
}

model OrderItem {
  id        BigInt @id @default(autoincrement())
  orderId   BigInt
  productId BigInt

  name     String
  price    Decimal @db.Decimal(12, 2)
  quantity Int
  total    Decimal @db.Decimal(12, 2)

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product  @relation(fields: [productId], references: [id])
  refunds Refund[]

  @@index([orderId])
  @@index([productId])
}

model Payment {
  id            BigInt        @id @default(autoincrement())
  orderId       BigInt
  paymentMethod PaymentMethod
  status        PaymentStatus @default(INITIATED)

  amount   Decimal @db.Decimal(12, 2)
  currency String  @default("INR")

  gateway         String
  gatewayTxnId    String?
  gatewayResponse Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  refunds Refund[]

  @@index([orderId])
}

model Refund {
  id BigInt @id @default(autoincrement())

  orderItemId BigInt
  paymentId   BigInt

  amount Decimal      @db.Decimal(12, 2)
  status RefundStatus @default(PENDING)

  gatewayRefundId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  payment   Payment   @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  orderItem OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@index([paymentId])
  @@index([orderItemId])
}

model Product {
  id          BigInt  @id @default(autoincrement())
  publicId    String  @unique @default(uuid())
  name        String
  description String
  price       Decimal @db.Decimal(12, 2)
  category    String
  rating      Float   @default(0)
  stock       Int     @default(0)
  imageUrl    String?
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orderItems OrderItem[]
}
